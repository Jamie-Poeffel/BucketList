{
    "compilerOptions": {
        "target": "ES6",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "./dist",
        "types": [
            "jest"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*",
        "__test__/app.test.ts"
    ],
    "exclude": [
        "node_modules",
        "**/*.test.ts"
    ]
}